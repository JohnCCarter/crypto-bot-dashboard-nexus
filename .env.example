# 🔐 TRADING BOT ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your actual values

# ===========================================
# 🏦 EXCHANGE CONFIGURATION (Bitfinex)
# ===========================================
EXCHANGE_ID=bitfinex
BITFINEX_API_KEY=your_bitfinex_api_key_here
BITFINEX_API_SECRET=your_bitfinex_api_secret_here

# ===========================================
# 🔒 SECURITY & AUTHENTICATION  
# ===========================================
JWT_SECRET_KEY=your_super_secret_jwt_key_here_minimum_32_characters
JWT_EXPIRY_HOURS=24
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_secure_admin_password_here

# ===========================================
# 🗄️ DATABASE CONFIGURATION (Supabase)
# ===========================================
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here
# Note: Use service_role key for full database access

# ===========================================
# ⚙️ RISK MANAGEMENT SETTINGS
# ===========================================
MAX_POSITION_SIZE=0.1
MAX_LEVERAGE=3.0
STOP_LOSS_PCT=2.0
TAKE_PROFIT_PCT=4.0
MAX_DAILY_LOSS=5.0
MAX_OPEN_POSITIONS=5
MIN_SIGNAL_CONFIDENCE=0.6
PROBABILITY_WEIGHT=0.5
RISK_PER_TRADE=0.02
LOOKBACK=5

# ===========================================
# 🌍 DEPLOYMENT SETTINGS
# ===========================================
ENVIRONMENT=development
# Set to "production" for live trading
ALLOWED_ORIGINS=http://localhost:8081,http://127.0.0.1:8081
# Comma-separated list of allowed frontend origins for CORS

# ===========================================
# 📊 LOGGING & MONITORING
# ===========================================
LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARNING, ERROR